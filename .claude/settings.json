{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "command": "/opt/homebrew/bin/python3 -m code_review_graph update --quiet",
        "timeout": 5000
      }
    ],
    "SessionStart": [
      {
        "command": "/opt/homebrew/bin/python3 -m code_review_graph status --json",
        "timeout": 3000
      }
    ],
    "PreCommit": [
      {
        "command": "/opt/homebrew/bin/python3 -m code_review_graph detect-changes --brief",
        "timeout": 10000
      }
    ]
  }
}
