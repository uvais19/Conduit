{
  "mcpServers": {
    "code-review-graph": {
      "command": "/opt/homebrew/bin/python3",
      "args": ["-m", "code_review_graph", "serve"],
      "type": "stdio"
    },
    "stitch": {
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
          "X-Goog-Api-Key": "${STITCH_API_KEY}"
      }
    }
  }
}
